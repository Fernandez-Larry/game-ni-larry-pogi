#!/bin/sh
# post-commit hook: push current branch to remote 'origin'
# This hook is designed to be versioned in the repository. Enable it by
# running `git config core.hooksPath .githooks` (see scripts/setup-hooks.ps1).

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ -z "$BRANCH" ]; then
  echo "Could not determine current branch; skipping auto-push." >&2
  exit 0
fi

echo "Auto-push: pushing branch $BRANCH to origin..."
git push origin "$BRANCH" --quiet 2>> .git/hooks/push-errors.log || {
  echo "Auto-push failed; see .git/hooks/push-errors.log for details." >&2
  exit 0
}

echo "Auto-push done."
